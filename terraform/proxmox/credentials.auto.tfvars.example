# Copy to credentials.prod.tfvars and fill in values.
# credentials.*.tfvars are gitignored.

proxmox_endpoint  = "https://192.168.1.10:8006/"
proxmox_api_token = "terraform@pve!terraform=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_node      = "nodename"

# Talos (optional). Image is downloaded on the Proxmox node by default; set talos_image_id to skip that.
# Set DHCP reservations on your router for these IPs to match each VM’s MAC (Proxmox → VM → Hardware → Network).
# enable_talos_cluster      = true
# talos_controlplane_ip     = "192.168.1.210"
# talos_worker_ips          = ["192.168.1.211", "192.168.1.212"]
# talos_controlplane_vm_id  = 210
# talos_worker_vm_ids       = [211, 212]
# talos_version             = "1.12.6"
