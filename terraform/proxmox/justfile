env := "dev"
unraid_host := "fern.lan"
nixos_flake := "github:reidmason/dotfiles#github-runner-" + env
# Proxmox directory `local` images layout: files live under /var/lib/vz/images/<id>/ (volid local:<id>/file.qcow2). Not a real VM ID.
image_lib := "999"

# Write proxmox.s3.tfbackend using Garage credentials from Unraid (run once, or on new machine)
setup-backend host=unraid_host:
    bash {{justfile_directory()}}/setup-backend.sh {{host}}

# Create the Terraform user, API token, permissions, and storage config on a fresh Proxmox host
bootstrap proxmox_host env=env:
    bash {{justfile_directory()}}/bootstrap-proxmox.sh {{proxmox_host}} {{env}}

# Optional: raw→qcow2 under images/999 for import_from workflows (current Talos stack uses boot ISO + empty disk instead).
# Requires: curl, zstd, qemu-img, ssh. version must match talos_version in tfvars.
upload-talos-image proxmox_host version='1.12.6':
    #!/usr/bin/env bash
    set -euo pipefail
    ver="{{version}}"
    tmp=$(mktemp -d)
    trap 'rm -rf "$tmp"' EXIT
    curl -fL -o "$tmp/metal-amd64.raw.zst" "https://github.com/siderolabs/talos/releases/download/v${ver}/metal-amd64.raw.zst"
    zstd -d "$tmp/metal-amd64.raw.zst" -o "$tmp/metal-amd64.raw"
    qemu-img convert -f raw -O qcow2 "$tmp/metal-amd64.raw" "$tmp/talos-metal-amd64.qcow2"
    ssh root@{{proxmox_host}} "mkdir -p /var/lib/vz/images/{{image_lib}}"
    scp "$tmp/talos-metal-amd64.qcow2" root@{{proxmox_host}}:/var/lib/vz/images/{{image_lib}}/talos-metal-amd64.qcow2
    ssh root@{{proxmox_host}} "chmod 644 /var/lib/vz/images/{{image_lib}}/talos-metal-amd64.qcow2"

# Build the NixOS cloud image from the runner config and upload it to Proxmox
# Requires: nix, ssh access to Proxmox host. Re-run on NixOS version bumps or config changes.
upload-image proxmox_host:
    nix flake metadata github:reidmason/dotfiles --refresh > /dev/null
    nix run github:nix-community/nixos-generators -- \
        --format qcow \
        --flake {{nixos_flake}} \
        -o /tmp/nixos-image
    ssh root@{{proxmox_host}} "mkdir -p /var/lib/vz/images/{{image_lib}}"
    scp /tmp/nixos-image/nixos.qcow2 root@{{proxmox_host}}:/var/lib/vz/images/{{image_lib}}/nixos-cloud.qcow2
    ssh root@{{proxmox_host}} "chmod 644 /var/lib/vz/images/{{image_lib}}/nixos-cloud.qcow2"

# Place a GitHub runner registration token on the VM and restart the runner service
# Generate a token at: https://github.com/reidmason/homelab/settings/actions/runners/new
register-runner token:
    #!/usr/bin/env bash
    IP=$(terraform workspace select -or-create {{env}} > /dev/null && terraform output -raw runner_ip)
    ssh root@$IP "mkdir -p /var/lib/secrets && chmod 700 /var/lib/secrets && echo '{{token}}' > /var/lib/secrets/github-runner-token && chmod 600 /var/lib/secrets/github-runner-token && systemctl restart github-runner-{{env}}.service"
    echo "Runner registered at $IP"

# Apply latest dotfiles flake on the runner (nixos-rebuild + home-manager), same as autoUpgrade's switch path
deploy-runner env=env:
    #!/usr/bin/env bash
    set -euo pipefail
    FLAKE="github:reidmason/dotfiles#github-runner-{{env}}"
    IP=$(terraform workspace select -or-create {{env}} > /dev/null && terraform output -raw runner_ip)
    ssh root@$IP "nixos-rebuild switch --flake $FLAKE && nix run github:nix-community/home-manager -- switch --flake $FLAKE"

init:
    terraform init -backend-config=proxmox.s3.tfbackend
    terraform workspace select --or-create {{env}}

plan:
    terraform workspace select {{env}}
    terraform plan -var-file=credentials.{{env}}.tfvars

apply:
    terraform workspace select {{env}}
    terraform apply -var-file=credentials.{{env}}.tfvars
