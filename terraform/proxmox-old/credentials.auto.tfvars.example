# Copy to credentials.prod.tfvars and fill in values.
# credentials.*.tfvars are gitignored.

proxmox_endpoint  = "https://192.168.1.10:8006/"
proxmox_api_token = "terraform@pve!terraform=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_node      = "nodename"

# GitHub Actions runner VM (NixOS). Default false — set true, run just upload-image, then apply.
# enable_github_runner = true

# Talos (optional). Boot ISO is downloaded on the Proxmox node by default; set talos_image_id to a volid (e.g. local:iso/talos-metal-amd64.iso) to skip that.
# Set DHCP reservations on your router for each mac_address → ip. Omit mac_address (or "") for Proxmox-assigned MACs.
# enable_talos_cluster = true
# talos_controlplanes = [
#   { vm_id = 210, mac_address = "bc:24:11:aa:00:01", ip = "192.168.1.210" }
# ]
# talos_workers = [
#   { vm_id = 211, mac_address = "bc:24:11:aa:00:02", ip = "192.168.1.211" },
#   { vm_id = 212, mac_address = "bc:24:11:aa:00:03", ip = "192.168.1.212" },
# ]
# talos_version = "1.12.6"
